---
export const prerender = true;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Page Not Found | Adagio Docs</title>
    <style>
      :root {
        color-scheme: light;
        --bg: #f7f8f4;
        --fg: #17211b;
        --muted: #5e6b62;
        --card: #ffffff;
        --border: #d9dfd6;
        --accent: #1f6f4a;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        padding: 24px;
        font-family: Georgia, "Times New Roman", serif;
        background:
          radial-gradient(circle at top, rgba(31, 111, 74, 0.12), transparent 35%),
          linear-gradient(180deg, var(--bg), #eef2ec);
        color: var(--fg);
      }

      main {
        width: min(640px, 100%);
        padding: 40px;
        border: 1px solid var(--border);
        border-radius: 20px;
        background: color-mix(in srgb, var(--card) 90%, transparent);
        box-shadow: 0 24px 70px rgba(23, 33, 27, 0.08);
      }

      h1 {
        margin: 0 0 12px;
        font-size: clamp(2.5rem, 6vw, 4rem);
        line-height: 0.95;
      }

      p {
        margin: 0 0 18px;
        color: var(--muted);
        font-size: 1.05rem;
        line-height: 1.6;
      }

      a {
        color: var(--accent);
        font-weight: 700;
      }
    </style>
  </head>
  <body>
    <main>
      <h1>404</h1>
      <p>The page you requested does not exist or has moved.</p>
      <p>
        Return to the <a href="/">documentation home page</a> and navigate from there.
      </p>
    </main>
  </body>
</html>
